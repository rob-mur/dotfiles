+std::optional<WaylandVirtualKeyboard::KeyInfo>
+WaylandVirtualKeyboard::keysym_to_keycode(uint32_t keysym) {
+    if (!xkb_map) return std::nullopt;
+
+    xkb_keycode_t min_kc = xkb_keymap_min_keycode(xkb_map);
+    xkb_keycode_t max_kc = xkb_keymap_max_keycode(xkb_map);
+
+    for (xkb_keycode_t kc = min_kc; kc <= max_kc; kc++) {
+        xkb_layout_index_t num_layouts = xkb_keymap_num_layouts_for_key(xkb_map, kc);
+        for (xkb_layout_index_t layout = 0; layout < num_layouts; layout++) {
+            xkb_level_index_t num_levels =
+                xkb_keymap_num_levels_for_key(xkb_map, kc, layout);
+            for (xkb_level_index_t level = 0; level < num_levels; level++) {
+                const xkb_keysym_t* syms = nullptr;
+                int n = xkb_keymap_key_get_syms_by_level(
+                    xkb_map, kc, layout, level, &syms);
+                for (int i = 0; i < n; i++) {
+                    if (syms[i] == keysym) {
+                        // XKB keycodes are evdev+8; subtract to get Linux keycode
+                        uint32_t linux_kc = static_cast<uint32_t>(kc) - 8;
+                        bool shift = (level == 1);
+                        return KeyInfo{linux_kc, shift};
+                    }
+                }
+            }
+        }
+    }
+    return std::nullopt;
+}
+
+void WaylandVirtualKeyboard::send_key_for_keysym(uint32_t time, uint32_t keysym,
+                                                  uint32_t state) {
+    auto info = keysym_to_keycode(keysym);
+    if (!info) {
+        std::cerr << "No keycode found for keysym 0x" << std::hex << keysym
+                  << std::dec << std::endl;
+        return;
+    }
+
+    constexpr uint32_t KEY_LEFTSHIFT = 42;
+    if (state == 1) { // press
+        if (info->shift_needed)
+            send_key(time, KEY_LEFTSHIFT, 1);
+        send_key(time, info->keycode, 1);
+    } else { // release
+        send_key(time, info->keycode, 0);
+        if (info->shift_needed)
+            send_key(time, KEY_LEFTSHIFT, 0);
+    }
+}
